    "tokenlistview.delete.message" : {
      "comment" : "A message in an alert that informs the user that they are about to delete a TOTP token. First argument is the issuer, second is the account.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies entfernt den TOTP für %1$@ (%2$@) endgültig. Diese Aktion lässt sich nicht rückgängig machen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently remove the TOTP for %1$@ (%2$@). You can't undo this."
          }
        }
      }
    },
